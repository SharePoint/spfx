{
  "@microsoft/generator-sharepoint": {
    "whichFolder": "subdir",
    "solutionName": "<%= componentNameCapitalCase %>",
    "useGulp": false,
    "componentType": "extension",
    "extensionType": "FieldCustomizer",
    "template": "none",
    "componentName": "<%= componentNameCapitalCase %>",
    "plusBeta": false,
    "isCreatingSolution": true,
    "nodeVersion": "22.21.1",
    "sdksVersions": {},
    "version": "1.22.1",
    "libraryName": "<%= libraryName %>",
    "libraryId": "<%= solutionId %>",
    "environment": "spo",
    "packageManager": "npm",
    "solutionShortDescription": "<%= componentNameUnescaped %> description",
    "skipFeatureDeployment": true,
    "isDomainIsolated": false
  }
}
