{
  "$schema": "https://developer.microsoft.com/json-schemas/heft/v0/heft.schema.json",
  "phasesByName": {
    "build": {
      "tasksByName": {
        "lint": {
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft-lint-plugin"
          }
        },
        "webpack": {
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft-webpack5-plugin"
          }
        }
      },
      "phaseDescription": "Build SPFx components using a custom Webpack configuration.",
      "cleanFiles": [
        {
          "sourcePath": "dist"
        }
      ]
    },
    "test": {
      "phaseDescription": "Run tests using Jest.",
      "dependsOn": ["build"],
      "tasksByName": {
        "jest": {
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft-jest-plugin"
          }
        }
      }
    },
    "eject-webpack": {
      "tasksByName": {
        "eject-webpack": {
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft",
            "pluginName": "run-script-plugin",
            "options": {
              "scriptPath": "node_modules/@microsoft/spfx-heft-plugins/lib-commonjs/plugins/ejectWebpackPlugin/EjectWebpackPlugin.js"
            }
          }
        }
      }
    },
    "package-solution": {
      "phaseDescription": "Package the project as an SPPKG.",
      "tasksByName": {
        "package-solution": {
          "taskPlugin": {
            "pluginPackage": "@microsoft/spfx-heft-plugins",
            "pluginName": "package-solution-plugin"
          }
        }
      }
    }
  }
}