import { ISPFxAdaptiveCard, BaseAdaptiveCardQuickView } from '@microsoft/sp-adaptive-card-extension-base';
import * as strings from '<%= componentNamePascalCase %>AdaptiveCardExtensionStrings';
import {
  I<%= componentNamePascalCase %>AdaptiveCardExtensionProps,
  I<%= componentNamePascalCase %>AdaptiveCardExtensionState
} from '../<%= componentNamePascalCase %>AdaptiveCardExtension';

export interface IQuickViewData {
  subTitle: string;
  title: string;
}

export class QuickView extends BaseAdaptiveCardQuickView<
  I<%= componentNamePascalCase %>AdaptiveCardExtensionProps,
  I<%= componentNamePascalCase %>AdaptiveCardExtensionState,
  IQuickViewData
> {
  public get data(): IQuickViewData {
    return {
      subTitle: strings.SubTitle,
      title: strings.Title
    };
  }

  public get template(): ISPFxAdaptiveCard {
    return require('./template/QuickViewTemplate.json');
  }
}
